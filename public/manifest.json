{
  "manifest_version": 3,
  "name": "Ontico Kanban",
  "description": "Канбан-доска для заявок конференции ontico.ru",
  "version": "1.0.0",
  "permissions": ["tabs"],
  "host_permissions": ["*://conf.ontico.ru/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ontico Kanban",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["kanban.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
